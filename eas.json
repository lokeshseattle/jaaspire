{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_WEB_ORIGIN": "https://stgx.jaaspire.com",
        "EXPO_PUBLIC_API_BASE_URL": "https://stgx.jaaspire.com/api/v1"
      }
    },
    "preview": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_WEB_ORIGIN": "https://stgx.jaaspire.com",
        "EXPO_PUBLIC_API_BASE_URL": "https://stgx.jaaspire.com/api/v1"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_WEB_ORIGIN": "https://stgx.jaaspire.com",
        "EXPO_PUBLIC_API_BASE_URL": "https://stgx.jaaspire.com/api/v1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
