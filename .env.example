# Copy to `.env` for local dev (see src/constants/app-env.ts and app.config.ts).
# EAS builds: set the same vars per profile in eas.json → build.<profile>.env

# Public site / Universal Links origin (no trailing slash)
EXPO_PUBLIC_WEB_ORIGIN=https://stgx.jaaspire.com

# Optional — defaults to ${EXPO_PUBLIC_WEB_ORIGIN}/api/v1
# EXPO_PUBLIC_API_BASE_URL=https://stgx.jaaspire.com/api/v1
