{
  "expo": {
    "name": "Jaaspire",
    "slug": "jaaspire",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jaaspire",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.convoia.jaaspire",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Jaaspire accesses your photo library to select photos and videos for your profile, posts, stories, and chat messages.",
        "NSCameraUsageDescription": "Jaaspire uses your camera to capture photos and videos for your profile, posts, stories, and chat messages.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos to your library.",
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver a more personalized experience and track ad campaign performance."
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "appleTeamId": "T6Y9862AD6"
    },
    "android": {
      "package": "com.convoia.jaaspire",
      "icon": "./assets/images/icon.png",
      "softwareKeyboardLayoutMode": "resize",
      // "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "com.android.vending.BILLING",
        "com.android.vending.INSTALL_REFERRER"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f5f5f5",
          "image": "./assets/images/icon.png",
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Jaaspire accesses your photo library to select photos and videos for your profile, posts, stories, and chat messages.",
          "cameraPermission": "Jaaspire uses your camera to capture photos and videos for your profile, posts, stories, and chat messages.",
          "microphonePermission": "Jaaspire uses your microphone to record audio when you capture videos for posts, stories, and chat messages."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-iap",
      "expo-notifications",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This identifier will be used to deliver a more personalized experience and track ad campaign performance."
        }
      ],
      "@react-native-firebase/app/app.plugin.js",
      [
        "@react-native-firebase/analytics/app.plugin.js",
        {
          "ios": {
            "withoutAdIdSupport": false,
            "googleAppMeasurementOnDeviceConversion": true
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBAnalytics"]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "239223f2-2e9c-40db-992f-eb46109b3696"
      }
    },
    "owner": "convoia",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/239223f2-2e9c-40db-992f-eb46109b3696"
    }
  }
}
